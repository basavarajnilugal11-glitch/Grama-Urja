<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚡ Grama-Urja"
                    android:textColor="@color/green_primary"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium"/>

                <TextView
                    android:id="@+id/tvGreeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hello, Farmer 👋"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"/>

            </LinearLayout>

            <TextView
                android:id="@+id/tvLocationBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📍 Your Village"
                android:textColor="@color/amber_primary"
                android:textSize="11sp"
                android:background="@drawable/bg_badge_amber"
                android:padding="6dp"/>

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="YOUR ZONE"
            android:textColor="@color/text_muted"
            android:textSize="10sp"
            android:letterSpacing="0.1"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tvZoneName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your Village"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium"/>

        <TextView
            android:id="@+id/tvZoneSub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mandya Taluk"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:layout_marginBottom="12dp"/>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardPowerStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/power_on_bg"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="24dp">

                <ImageView
                    android:id="@+id/ivPowerIcon"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_bolt"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvPowerStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="POWER IS ON"
                    android:textColor="@color/green_primary"
                    android:textSize="24sp"
                    android:fontFamily="sans-serif-medium"/>

                <TextView
                    android:id="@+id/tvPowerUpdated"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Live from Firebase ⚡"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginTop="6dp"
                    android:gravity="center"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btnPowerOn"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="⚡ Power ON"
                android:textSize="13sp"
                android:backgroundTint="@color/green_dark"
                android:textColor="@color/green_primary"
                style="@style/Widget.MaterialComponents.Button"/>

            <Button
                android:id="@+id/btnPowerOff"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="🔴 Power OFF"
                android:textSize="13sp"
                android:backgroundTint="@color/surface_card"
                android:textColor="@color/text_secondary"
                style="@style/Widget.MaterialComponents.Button"/>

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="COMMUNITY FEED"
            android:textColor="@color/text_muted"
            android:textSize="10sp"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/surface_card"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="LIVE UPDATES FROM YOUR ZONE"
                    android:textColor="@color/text_muted"
                    android:textSize="10sp"
                    android:padding="14dp"
                    android:letterSpacing="0.1"
                    android:background="@color/surface_header"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvCommunityFeed"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>