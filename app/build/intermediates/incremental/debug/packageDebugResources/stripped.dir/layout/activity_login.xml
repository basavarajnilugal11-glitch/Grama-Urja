<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Top logo area -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="48dp"
            android:paddingBottom="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚡"
                android:textSize="52sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ಗ್ರಾಮ-ಊರ್ಜ"
                android:textColor="@color/green_primary"
                android:textSize="24sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Grama-Urja"
                android:textColor="@color/green_light"
                android:textSize="16sp"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

        <!-- Login card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/surface_card"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Login / Register"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Join your village power network"
                    android:textColor="@color/text_muted"
                    android:textSize="13sp"
                    android:layout_marginBottom="24dp"/>

                <!-- Name field -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👤  Full Name"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginBottom="6dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxStrokeColor="@color/divider"
                    app:boxBackgroundColor="@color/background_dark"
                    app:hintTextColor="@color/text_muted">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="e.g. Raju Kumar"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_muted"
                        android:inputType="textPersonName"
                        android:textSize="15sp"/>

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Phone field -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📱  Mobile Number"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginBottom="6dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxStrokeColor="@color/divider"
                    app:boxBackgroundColor="@color/background_dark"
                    app:hintTextColor="@color/text_muted"
                    app:prefixText="+91 "
                    app:prefixTextColor="@color/green_primary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPhone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="10-digit number"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_muted"
                        android:inputType="phone"
                        android:maxLength="10"
                        android:textSize="15sp"/>

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Village/Zone field -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📍  Your Village / Zone"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginBottom="6dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxStrokeColor="@color/divider"
                    app:boxBackgroundColor="@color/background_dark"
                    app:hintTextColor="@color/text_muted">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etZone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="e.g. Hebbalaguppe"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_muted"
                        android:inputType="textCapWords"
                        android:textSize="15sp"/>

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Quick zone chips -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Quick select:"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="24dp">

                    <TextView
                        android:id="@+id/chipHebbalaguppe"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hebbalaguppe"
                        android:textColor="@color/green_primary"
                        android:textSize="11sp"
                        android:background="@drawable/bg_chip"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="5dp"
                        android:paddingBottom="5dp"
                        android:layout_marginEnd="6dp"
                        android:clickable="true"
                        android:focusable="true"/>

                    <TextView
                        android:id="@+id/chipMalavalli"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Malavalli"
                        android:textColor="@color/green_primary"
                        android:textSize="11sp"
                        android:background="@drawable/bg_chip"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="5dp"
                        android:paddingBottom="5dp"
                        android:layout_marginEnd="6dp"
                        android:clickable="true"
                        android:focusable="true"/>

                    <TextView
                        android:id="@+id/chipSrirangapatna"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Srirangapatna"
                        android:textColor="@color/green_primary"
                        android:textSize="11sp"
                        android:background="@drawable/bg_chip"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="5dp"
                        android:paddingBottom="5dp"
                        android:clickable="true"
                        android:focusable="true"/>

                </LinearLayout>

                <!-- Login button -->
                <Button
                    android:id="@+id/btnLogin"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Join Network →"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"
                    android:backgroundTint="@color/green_primary"
                    android:textColor="@color/background_dark"
                    style="@style/Widget.MaterialComponents.Button"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Skip -->
        <TextView
            android:id="@+id/tvSkip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Skip for now"
            android:textColor="@color/text_muted"
            android:textSize="13sp"
            android:paddingTop="16dp"
            android:paddingBottom="8dp"
            android:clickable="true"
            android:focusable="true"/>

        <!-- Privacy note -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔒 Your number is only used for power alerts. We never share it."
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:gravity="center"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="32dp"
            android:lineSpacingMultiplier="1.4"/>

    </LinearLayout>
</ScrollView>
